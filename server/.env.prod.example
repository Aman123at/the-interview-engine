# Copy to .env.prod and fill in. Used by both:
#   docker compose -f docker-compose.build.yml ...   (local build + push)
#   docker compose -f docker-compose.prod.yml  ...   (VPS pull + run)
# Real secrets live in ./infra/secrets/*.txt (chmod 600, git-ignored).

APP_DOMAIN=interviewme.com
ACME_EMAIL=ops@interviewme.com

# Docker Hub (or any OCI registry) tags. Bump the version on every release;
# `pull_policy: always` ensures the VPS picks up the new digest on `up -d`.
SERVER_IMAGE=youruser/interview-sandbox-server:v1.0.0
CLIENT_IMAGE=youruser/interview-sandbox-client:v1.0.0
