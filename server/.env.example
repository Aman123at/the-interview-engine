NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# Comma-separated list of allowed client origins (localhost dev)
CORS_ORIGINS=http://localhost:3000

# Postgres
DATABASE_URL=postgres://postgres:postgres@localhost:5432/interview_sandbox
DATABASE_POOL_MAX=10

# Seed users — JSON array; only used by `pnpm seed`. Plaintext passwords get bcrypt-hashed at seed time.
# Example: '[{"email":"alice@acme.com","password":"hunter22","displayName":"Alice","role":"admin"}]'
SEED_USERS=[{"email":"interviewer@example.com","password":"changeme123","displayName":"Default Interviewer","role":"interviewer"}]

# Shutdown
SHUTDOWN_TIMEOUT_MS=10000

# Auth — generate strong random secrets in real envs: `openssl rand -hex 48`
JWT_ACCESS_SECRET=dev-access-secret-change-me-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
REFRESH_COOKIE_NAME=isb_rt
ACCESS_COOKIE_NAME=isb_at
LOGIN_RATE_WINDOW_MS=60000
LOGIN_RATE_MAX=10

# ---- Preview wiring ----
# 'localhost' (default) — publish a host port per session; preview at http://localhost:<port>.
# 'subdomain'           — no host port; container is attached to SANDBOX_NETWORK
#                         and Traefik labels are stamped so https://<sessionId>.<PREVIEW_BASE_DOMAIN> routes to it.
PREVIEW_MODE=localhost
# Required when PREVIEW_MODE=subdomain.
# PREVIEW_BASE_DOMAIN=sandbox.interviewme.com
# PREVIEW_SCHEME=https           # default: https in subdomain mode, http in localhost mode
# SANDBOX_NETWORK=sandbox        # docker network shared with traefik in subdomain mode
# TRAEFIK_CERTRESOLVER=le
# TRAEFIK_ENTRYPOINT=websecure
# TRAEFIK_PREVIEW_MIDDLEWARE=preview-csp@file

# ---- Docker connection ----
# Local dev uses the unix socket (auto-detected; override via DOCKER_SOCKET).
# In prod, point at a docker-socket-proxy: DOCKER_HOST=tcp://dockerproxy:2375
# DOCKER_HOST=tcp://dockerproxy:2375
# DOCKER_SOCKET=/var/run/docker.sock

# ---- Auth cookies + CORS ----
# Localhost dev: host-only cookies, Secure=false, SameSite=lax → just CORS_ORIGINS is enough.
# Subdomain prod: set COOKIE_DOMAIN=.<base>, COOKIE_SECURE=true, COOKIE_SAMESITE=lax|none,
# and CLIENT_ORIGIN to the canonical client origin (auto-unioned with CORS_ORIGINS).
# CLIENT_ORIGIN=https://app.interviewme.com
# COOKIE_DOMAIN=.interviewme.com
# COOKIE_SECURE=true
# COOKIE_SAMESITE=lax
